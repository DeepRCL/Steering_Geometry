# ── Hugging Face ─────────────────────────────────────────────────────────────
HF_TOKEN=your_hf_token_here

# ── Google Gemini (value mapping) ────────────────────────────────────────────
GEMINI_API_KEYS=your_key_1,your_key_2,your_key_3
GEMINI_MODEL=gemini-3.1-flash-lite-preview

# ── OpenRouter ────────────────────────────────────────────────────────────────
OPENROUTER_API_KEY=your_openrouter_api_key_here

# ── Answer generation (ValueBench / Touche23) ────────────────────────────────
MODEL_ID=Qwen/Qwen3.5-2B
MAX_NEW_TOKENS=512
DEVICE_MAP=auto
INPUT_CSV=dataset_positive_only.csv
BATCH_SIZE=10
DEBUG_ROWS=10

# ── Value stability (perturbation) ───────────────────────────────────────────
PERTURBATION_MODEL_ID=Qwen/Qwen3.5-2B
PERTURBATION_MAX_NEW_TOKENS=2048
PERTURBATION_INPUT_CSV=final_dataset_v3.csv
PARAPHRASE_OUTPUT_CSV=final_dataset_paraphrased.csv
ADVERSARIAL_OUTPUT_CSV=final_dataset_adversarial.csv
PERTURBATION_DEBUG_ROWS=10
